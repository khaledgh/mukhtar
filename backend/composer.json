{
    "name": "mokhtar/voter-search-backend",
    "description": "Slim Framework 4 API backend for electoral search",
    "require": {
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "process-timeout": 0,
        "allow-plugins": {
            "slim/slim-psr7": true
        }
    }
}
